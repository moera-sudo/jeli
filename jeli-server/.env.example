# * База данных (для локального запуска без Docker используйте localhost;
# * внутри docker-compose backend всегда подключается по имени сервиса "db")
DATABASE_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# * Хост-порты для docker-compose — поменяйте, если 5432/8000 уже заняты локально
POSTGRES_PORT=0
BACKEND_PORT=0

# * JWT (stateless: и access, и refresh — обычные JWT без хранения в БД)
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=0
REFRESH_TOKEN_EXPIRE_DAYS=0

# * CORS — список источников через запятую (адреса фронтенда)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# * Логирование
LOG_LEVEL=INFO
